{
  "openai_config": {
    "description": "基础配置",
    "type": "object",
    "hint": "OpenAi的接入网址和ApiKey",
    "items": {
      "base_url": {
        "description": "base_url",
        "type": "string",
        "hint": "支持OpenAi Api的接入网址"
      },
      "api_key": {
        "description": "api_key",
        "type": "string",
        "hint": "你的Api_Key"
      },
      "model": {
        "description": "模型名称",
        "type": "string",
        "hint": "需要调用的模型名称例如 gpt-image-2"
      },
      "size": {
        "description": "默认尺寸",
        "type": "string",
        "hint": "默认尺寸为1024x1024，GPT-Image-2支持（1024x1024, 1536x1024, 1024x1536, 2048x2048, 2048x1152, 3840x2160, 2160x3840）"
      },
      "timeout": {
        "description": "超时时间(秒)",
        "type": "int",
        "default": 180,
        "hint": "请求超时时间(默认180s)，推荐120s-300s"
      }
    }
  }
}